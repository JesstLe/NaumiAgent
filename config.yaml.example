# NaumiAgent 配置文件（示例）
# 复制为 .naumi/config.yaml；密钥请存入系统凭据库或环境变量

models:
  provider: "kimi"
  # 可选：provider catalog 路径；相对路径以此配置文件所在目录为基准。
  # catalog_path: "providers.json"
  default_model: "openai/kimi-for-coding"
  fast_model: "openai/kimi-for-coding"
  reasoning_model: "openai/kimi-for-coding"
  # 模型思考强度；auto 表示不发送强度参数，使用供应商默认值。
  reasoning_effort: auto
  max_tokens: 4096
  temperature: 1.0
  api_base: "https://api.kimi.com/coding/v1"
  # 使用 `naumi configure` 写入系统凭据库，或通过 NAUMI_MODELS__API_KEY 注入。
  model_info:
    openai/kimi-for-coding:
      max_context: 256000
    # 直连模型可在这里声明经过当前 API/LiteLLM 验证的强度能力。
    # anthropic/claude-opus-4-6:
    #   reasoning_efforts: [low, medium, high, max]
    #   default_reasoning_effort: high
    #   reasoning_effort: high

memory:
  session_db_path: "data/sessions.db"
  vector_db_path: "data/chroma"
  compaction_threshold: 0.75

search:
  # 实际 token 不写入 YAML；运行时从环境变量解析。
  provider_order: [brave, duckduckgo, browser]
  brave:
    enabled: true
    api_key_ref: "{env:BRAVE_SEARCH_API_KEY}"
    # 以下均为可选 Brave Web Search 参数。
    country: null
    search_lang: null
    ui_lang: null
    safesearch: moderate
    spellcheck: true
    freshness: null
    timeout_seconds: 10

# 交互式 naumi 始终把启动命令所在目录绑定为本轮工作区。
# 此字段保留给 API、部署等非交互高级场景；"." 表示进程当前目录。
workspace_root: "."

safety:
  permission_mode: "moderate"
  allowed_dirs:
    - "."
  # 累计预算默认不限，但仍会持续记录费用与 Token 用量。
  max_budget_usd: null
  max_input_tokens: null
  max_output_tokens: null
  max_turns: 50
  # 同一工具批次与整个 Agent 集群分别限流；1 可用于串行排障。
  max_parallel_tools: 4
  max_parallel_agents: 4
  # 如需主动限额，可改为明确数值，例如：
  # max_budget_usd: 5.0
  # max_input_tokens: 500000
  # max_output_tokens: 50000

mcp:
  servers: {}

api:
  # 默认仅监听本机回环地址，避免默认暴露到局域网。
  # 只有在明确需要外部网络访问时，才可显式设置为 "0.0.0.0"，
  # 并务必同时配置 api_keys 和 cors_origins 进行加固。
  host: "127.0.0.1"
  # 默认端口 8765 与 Mac Workbench 本地 daemon 约定保持一致；
  # 如需使用其他端口，可显式覆盖或通过 --port 传入。
  port: 8765
  # 公开部署请配置，例如：["naumi-local-key-please-change"]
  api_keys: []
  cors_origins: ["*"]

browser_daemon:
  # 容器内默认关闭外部 daemon 适配；需要时可指向单独运行的服务。
  enabled: false
  base_url: "http://127.0.0.1:3005"
  project_dir: "/workspace/browser-debugging-daemon"

browser:
  # 同时执行的浏览器任务；每个任务使用独立运行时和产物目录。
  # 默认 2，范围 1-8；设为 1 可串行排障。
  max_concurrent_runs: 2
  # 保留的浏览器运行记录数量，范围 20-5000。
  run_history_limit: 200

log_level: "INFO"
