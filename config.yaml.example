# NaumiAgent 配置文件（示例）
# 复制为 config.yaml 并填入实际值

models:
  default_model: "openai/kimi-for-coding"
  fast_model: "openai/kimi-for-coding"
  reasoning_model: "openai/kimi-for-coding"
  max_tokens: 4096
  temperature: 0.7
  api_base: "https://api.kimi.com/coding/v1"
  # 推荐通过环境变量 NAUMI_MODELS__API_KEY 注入，避免把密钥写进文件。
  # api_key: "your-api-key-here"
  model_info:
    openai/kimi-for-coding:
      max_context: 256000

memory:
  session_db_path: "data/sessions.db"
  vector_db_path: "data/chroma"
  compaction_threshold: 0.75

# 相对路径文件操作和 bash 默认执行目录。
# "." 表示启动 naumi 进程时的当前目录。
workspace_root: "."

safety:
  permission_mode: "moderate"
  allowed_dirs:
    - "/workspace"
  max_budget_usd: 5.0
  max_turns: 30
  max_input_tokens: 500000

mcp:
  servers: {}

api:
  # 默认仅监听本机回环地址，避免默认暴露到局域网。
  # 只有在明确需要外部网络访问时，才可显式设置为 "0.0.0.0"，
  # 并务必同时配置 api_keys 和 cors_origins 进行加固。
  host: "127.0.0.1"
  port: 8080
  # 公开部署请配置，例如：["naumi-local-key-please-change"]
  api_keys: []
  cors_origins: ["*"]

browser_daemon:
  # 容器内默认关闭外部 daemon 适配；需要时可指向单独运行的服务。
  enabled: false
  base_url: "http://127.0.0.1:3005"
  project_dir: "/workspace/browser-debugging-daemon"

log_level: "INFO"
