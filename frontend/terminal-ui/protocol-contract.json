{
  "version": 1,
  "transport": "jsonl",
  "negotiation": {
    "minimum_version": 1,
    "maximum_version": 1,
    "capabilities": [
      "goal_snapshot",
      "heartbeat",
      "task_snapshot",
      "typed_ui_messages",
      "workbench_snapshot",
      "workbench_proposal_actions"
    ],
    "required_capabilities": [
      "typed_ui_messages"
    ]
  },
  "client_events": [
    "hello",
    "submit",
    "task_submit",
    "run_cancel",
    "queue_promote",
    "queue_cancel",
    "receipt/request",
    "harness/explain/request",
    "harness/replay/request",
    "harness/eval-baseline/request",
    "harness/eval-batch/request",
    "harness/eval-promotion/request",
    "inspector/request",
    "agents/request",
    "agents/stop",
    "workbench/request",
    "workbench/review/request",
    "workbench/proposal/action",
    "evolution/review/request",
    "set_mode",
    "cycle_mode",
    "set_reasoning",
    "permission_response",
    "interaction_response",
    "interaction_cancel",
    "permission_revoke",
    "resume",
    "goal_panel",
    "task_panel",
    "task_cancel",
    "permissions_panel",
    "doctor",
    "ping",
    "shutdown"
  ],
  "server_events": [
    "ready",
    "ack",
    "error",
    "pong",
    "user/message",
    "task/created",
    "ui/message",
    "engine/event",
    "completion/receipt",
    "harness/receipt",
    "harness/explain",
    "harness/replay",
    "harness/eval-baseline",
    "harness/eval-batch",
    "harness/eval-promotion",
    "doctor/health",
    "inspector/snapshot",
    "inspector/update",
    "agents/snapshot",
    "agents/update",
    "agents/action",
    "run/queued",
    "run/queue_promoted",
    "run/queue_cancelled",
    "run/started",
    "run/completed",
    "run/cancelled",
    "session/replayed",
    "runtime/status",
    "mode/changed",
    "permission/request",
    "permission/resolved",
    "interaction/request",
    "interaction/resolved",
    "permission/grants_changed",
    "permissions/snapshot",
    "goals/snapshot",
    "tasks/snapshot",
    "debug/trace",
    "workbench/snapshot",
    "workbench/event",
    "workbench/review",
    "workbench/proposal/action_result",
    "evolution/review",
    "shutdown"
  ],
  "event_registry": {
    "client": {
      "hello": {"owner":"protocol","stability":"stable","criticality":"control","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "submit": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"never","sensitive_fields":["payload.text"],"redaction":"required"},
      "task_submit": {"owner":"tasks","stability":"stable","criticality":"control","persistence":"never","sensitive_fields":["payload.text"],"redaction":"required"},
      "run_cancel": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "queue_promote": {"owner":"runtime","stability":"experimental","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "queue_cancel": {"owner":"runtime","stability":"experimental","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "receipt/request": {"owner":"harness","stability":"stable","criticality":"control","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "harness/explain/request": {"owner":"harness","stability":"stable","criticality":"control","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "harness/replay/request": {"owner":"harness","stability":"stable","criticality":"control","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "harness/eval-baseline/request": {"owner":"harness","stability":"stable","criticality":"control","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "harness/eval-batch/request": {"owner":"harness","stability":"experimental","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "harness/eval-promotion/request": {"owner":"harness","stability":"experimental","criticality":"control","persistence":"audit","sensitive_fields":["payload.reason"],"redaction":"required"},
      "inspector/request": {"owner":"inspector","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "agents/request": {"owner":"agents","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "agents/stop": {"owner":"agents","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "workbench/request": {"owner":"workbench","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "workbench/review/request": {"owner":"workbench","stability":"experimental","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "workbench/proposal/action": {"owner":"workbench","stability":"experimental","criticality":"control","persistence":"audit","sensitive_fields":["payload.decision_note"],"redaction":"required"},
      "evolution/review/request": {"owner":"evolution","stability":"experimental","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "set_mode": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "cycle_mode": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "set_reasoning": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "permission_response": {"owner":"safety","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "interaction_response": {"owner":"safety","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":["payload.custom_text"],"redaction":"required"},
      "interaction_cancel": {"owner":"safety","stability":"experimental","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "permission_revoke": {"owner":"safety","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "resume": {"owner":"sessions","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "goal_panel": {"owner":"runtime","stability":"experimental","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "task_panel": {"owner":"tasks","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "task_cancel": {"owner":"tasks","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "permissions_panel": {"owner":"safety","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "doctor": {"owner":"diagnostics","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "ping": {"owner":"protocol","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "shutdown": {"owner":"protocol","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":[],"redaction":"none"}
    },
    "server": {
      "ready": {"owner":"protocol","stability":"stable","criticality":"control","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "ack": {"owner":"protocol","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "error": {"owner":"runtime","stability":"stable","criticality":"terminal","persistence":"timeline","sensitive_fields":["payload.message"],"redaction":"required"},
      "pong": {"owner":"protocol","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":[],"redaction":"none"},
      "user/message": {"owner":"ui","stability":"stable","criticality":"informational","persistence":"timeline","sensitive_fields":["payload.content"],"redaction":"required"},
      "task/created": {"owner":"tasks","stability":"stable","criticality":"control","persistence":"timeline","sensitive_fields":["payload.mission","payload.task"],"redaction":"required"},
      "ui/message": {"owner":"ui","stability":"stable","criticality":"informational","persistence":"timeline","sensitive_fields":["payload.content"],"redaction":"required"},
      "engine/event": {"owner":"runtime","stability":"experimental","criticality":"informational","persistence":"never","sensitive_fields":["payload.data"],"redaction":"required"},
      "completion/receipt": {"owner":"runtime","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "harness/receipt": {"owner":"harness","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "harness/explain": {"owner":"harness","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "harness/replay": {"owner":"harness","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "harness/eval-baseline": {"owner":"harness","stability":"experimental","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "harness/eval-batch": {"owner":"harness","stability":"experimental","criticality":"terminal","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "harness/eval-promotion": {"owner":"harness","stability":"experimental","criticality":"terminal","persistence":"audit","sensitive_fields":["payload.promotion_reason"],"redaction":"required"},
      "doctor/health": {"owner":"diagnostics","stability":"experimental","criticality":"informational","persistence":"snapshot","sensitive_fields":["payload.items.detail","payload.items.suggestion"],"redaction":"required"},
      "inspector/snapshot": {"owner":"inspector","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "inspector/update": {"owner":"inspector","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "agents/snapshot": {"owner":"agents","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "agents/update": {"owner":"agents","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "agents/action": {"owner":"agents","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "run/queued": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"timeline","sensitive_fields":["payload.task"],"redaction":"required"},
      "run/queue_promoted": {"owner":"runtime","stability":"experimental","criticality":"control","persistence":"timeline","sensitive_fields":[],"redaction":"none"},
      "run/queue_cancelled": {"owner":"runtime","stability":"experimental","criticality":"terminal","persistence":"audit","sensitive_fields":["payload.reason"],"redaction":"required"},
      "run/started": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"timeline","sensitive_fields":["payload.task"],"redaction":"required"},
      "run/completed": {"owner":"runtime","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "run/cancelled": {"owner":"runtime","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":["payload.reason"],"redaction":"required"},
      "session/replayed": {"owner":"sessions","stability":"stable","criticality":"control","persistence":"timeline","sensitive_fields":["payload.messages"],"redaction":"required"},
      "runtime/status": {"owner":"runtime","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "mode/changed": {"owner":"runtime","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "permission/request": {"owner":"safety","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":["payload.arguments"],"redaction":"required"},
      "permission/resolved": {"owner":"safety","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "interaction/request": {"owner":"safety","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":["payload.question","payload.options"],"redaction":"required"},
      "interaction/resolved": {"owner":"safety","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":["payload.custom_text"],"redaction":"required"},
      "permission/grants_changed": {"owner":"safety","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":[],"redaction":"none"},
      "permissions/snapshot": {"owner":"safety","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":[],"redaction":"none"},
      "goals/snapshot": {"owner":"runtime","stability":"experimental","criticality":"informational","persistence":"snapshot","sensitive_fields":["payload.goals.objective","payload.goals.note","payload.goals.pursuit"],"redaction":"required"},
      "tasks/snapshot": {"owner":"tasks","stability":"experimental","criticality":"informational","persistence":"snapshot","sensitive_fields":["payload.items.title","payload.items.detail","payload.items.artifact_refs"],"redaction":"required"},
      "debug/trace": {"owner":"diagnostics","stability":"stable","criticality":"informational","persistence":"never","sensitive_fields":["payload.events_path","payload.transcript_path"],"redaction":"required"},
      "workbench/snapshot": {"owner":"workbench","stability":"stable","criticality":"informational","persistence":"snapshot","sensitive_fields":["payload.tasks","payload.events"],"redaction":"required"},
      "workbench/review": {"owner":"workbench","stability":"experimental","criticality":"informational","persistence":"snapshot","sensitive_fields":["payload.evidence.diff_hunks","payload.evidence.agent_notes","payload.evidence.events"],"redaction":"required"},
      "workbench/proposal/action_result": {"owner":"workbench","stability":"experimental","criticality":"control","persistence":"audit","sensitive_fields":["payload.message","payload.proposal"],"redaction":"required"},
      "workbench/event": {"owner":"workbench","stability":"stable","criticality":"control","persistence":"audit","sensitive_fields":["payload.payload"],"redaction":"required"},
      "evolution/review": {"owner":"evolution","stability":"experimental","criticality":"informational","persistence":"snapshot","sensitive_fields":["payload.items","payload.selected"],"redaction":"required"},
      "shutdown": {"owner":"protocol","stability":"stable","criticality":"terminal","persistence":"audit","sensitive_fields":[],"redaction":"none"}
    }
  },
  "runtime_status": {
    "reasoning_effort": {
      "fields": ["model", "effective", "source", "supported", "default", "warning"],
      "efforts": ["auto", "none", "minimal", "low", "medium", "high", "xhigh", "max"],
      "sources": ["runtime", "model", "global", "auto"]
    }
  },
  "harness_receipt": {
    "schema_version": 1,
    "fields": [
      "revision",
      "run_id",
      "status",
      "task_kind",
      "changed_files",
      "checks",
      "criteria",
      "warnings",
      "tree_fingerprint"
    ],
    "statuses": ["completed_verified", "completed_unverified", "blocked"],
    "limits": {
      "changed_files": 100,
      "checks": 50,
      "criteria": 100,
      "warnings": 50,
      "text_chars": 500,
      "stored_runs": 100
    }
  },
  "harness_explain": {
    "schema_version": 1,
    "fields": ["revision", "run_id", "lookup_status", "message", "explanation"],
    "lookup_statuses": ["ok", "not_found", "unavailable"],
    "limits": {
      "failure_classes": 20,
      "findings": 20,
      "checks": 50,
      "evidence": 100,
      "finding_check_ids": 50,
      "finding_evidence_ids": 100,
      "text_chars": 500,
      "stored_runs": 100
    }
  },
  "harness_replay": {
    "schema_version": 1,
    "fields": ["revision", "run_id", "lookup_status", "message", "result"],
    "lookup_statuses": ["ok", "not_found", "unavailable"],
    "statuses": ["reproduced", "changed", "partial", "corrupt"],
    "limits": {
      "timeline": 200,
      "artifacts": 100,
      "anomalies": 50,
      "differences": 50,
      "text_chars": 500,
      "stored_runs": 100
    }
  },
  "ui_messages": {
    "assistant_stream": {
      "fields": ["phase", "content"],
      "phases": ["start", "token", "end"]
    },
    "thinking": {
      "fields": ["phase", "content"],
      "phases": ["start", "delta", "end"]
    },
    "tool_prepare": {
      "fields": [
        "tool_name",
        "tool_call_id",
        "phase",
        "path",
        "argument_chars",
        "content_chars",
        "content_lines",
        "elapsed_ms",
        "todo_total",
        "todo_completed",
        "todo_open",
        "todo_items"
      ],
      "phases": ["start", "snapshot", "end"],
      "notes": "tool_prepare_end must remain available to the following tool_use so final tool cards can preserve prepare progress."
    },
    "tool_use": {
      "fields": ["tool_name", "tool_call_id", "primary_arg", "file_path", "command", "query", "url"]
    },
    "tool_result": {
      "fields": [
        "tool_name",
        "tool_call_id",
        "status",
        "duration_ms",
        "content_preview",
        "content_length",
        "preview_format",
        "preview_language",
        "content_truncated"
      ]
    },
    "todo_status": {
      "fields": ["source", "total_count", "open_count", "completed_count", "items", "summary_text"]
    },
    "permission_bubble": {
      "fields": ["agent_name", "tool_name", "status", "reason", "requires_confirmation"]
    },
    "runtime_status": {
      "fields": ["phase", "label", "duration_ms", "model", "turn"]
    },
    "system_notice": {
      "fields": ["title", "content", "level"]
    }
  },
  "workbench": {
    "schema_version": 1,
    "request_fields": ["session_id", "known_stream_id", "known_revision"],
    "snapshot_fields": [
      "stream_id", "revision", "generated_at", "full", "session_id", "counts",
      "active_selection", "missions", "tasks", "issues", "failures", "events"
    ],
    "event_fields": [
      "session_id", "stream_id", "revision", "id", "type", "actor", "subject_id",
      "payload", "timestamp"
    ]
  }
}
