{
  "version": 1,
  "transport": "jsonl",
  "client_events": [
    "hello",
    "submit",
    "task_submit",
    "run_cancel",
    "receipt/request",
    "harness/explain/request",
    "harness/replay/request",
    "inspector/request",
    "agents/request",
    "agents/stop",
    "set_mode",
    "cycle_mode",
    "set_reasoning",
    "permission_response",
    "interaction_response",
    "permission_revoke",
    "resume",
    "task_panel",
    "task_cancel",
    "permissions_panel",
    "doctor",
    "ping",
    "shutdown"
  ],
  "server_events": [
    "ready",
    "ack",
    "error",
    "pong",
    "user/message",
    "task/created",
    "ui/message",
    "engine/event",
    "completion/receipt",
    "harness/receipt",
    "harness/explain",
    "harness/replay",
    "inspector/snapshot",
    "inspector/update",
    "agents/snapshot",
    "agents/update",
    "agents/action",
    "run/queued",
    "run/started",
    "run/completed",
    "run/cancelled",
    "session/replayed",
    "runtime/status",
    "mode/changed",
    "permission/request",
    "permission/resolved",
    "interaction/request",
    "interaction/resolved",
    "permission/grants_changed",
    "debug/trace",
    "workbench/snapshot",
    "workbench/event",
    "shutdown"
  ],
  "runtime_status": {
    "reasoning_effort": {
      "fields": ["model", "effective", "source", "supported", "default", "warning"],
      "efforts": ["auto", "none", "minimal", "low", "medium", "high", "xhigh", "max"],
      "sources": ["runtime", "model", "global", "auto"]
    }
  },
  "harness_receipt": {
    "schema_version": 1,
    "fields": [
      "revision",
      "run_id",
      "status",
      "task_kind",
      "changed_files",
      "checks",
      "criteria",
      "warnings",
      "tree_fingerprint"
    ],
    "statuses": ["completed_verified", "completed_unverified", "blocked"],
    "limits": {
      "changed_files": 100,
      "checks": 50,
      "criteria": 100,
      "warnings": 50,
      "text_chars": 500,
      "stored_runs": 100
    }
  },
  "harness_explain": {
    "schema_version": 1,
    "fields": ["revision", "run_id", "lookup_status", "message", "explanation"],
    "lookup_statuses": ["ok", "not_found", "unavailable"],
    "limits": {
      "failure_classes": 20,
      "findings": 20,
      "checks": 50,
      "evidence": 100,
      "finding_check_ids": 50,
      "finding_evidence_ids": 100,
      "text_chars": 500,
      "stored_runs": 100
    }
  },
  "harness_replay": {
    "schema_version": 1,
    "fields": ["revision", "run_id", "lookup_status", "message", "result"],
    "lookup_statuses": ["ok", "not_found", "unavailable"],
    "statuses": ["reproduced", "changed", "partial", "corrupt"],
    "limits": {
      "timeline": 200,
      "artifacts": 100,
      "anomalies": 50,
      "differences": 50,
      "text_chars": 500,
      "stored_runs": 100
    }
  },
  "ui_messages": {
    "assistant_stream": {
      "fields": ["phase", "content"],
      "phases": ["start", "token", "end"]
    },
    "thinking": {
      "fields": ["phase", "content"],
      "phases": ["start", "delta", "end"]
    },
    "tool_prepare": {
      "fields": [
        "tool_name",
        "tool_call_id",
        "phase",
        "path",
        "argument_chars",
        "content_chars",
        "content_lines",
        "elapsed_ms",
        "todo_total",
        "todo_completed",
        "todo_open",
        "todo_items"
      ],
      "phases": ["start", "snapshot", "end"],
      "notes": "tool_prepare_end must remain available to the following tool_use so final tool cards can preserve prepare progress."
    },
    "tool_use": {
      "fields": ["tool_name", "tool_call_id", "primary_arg", "file_path", "command", "query", "url"]
    },
    "tool_result": {
      "fields": [
        "tool_name",
        "tool_call_id",
        "status",
        "duration_ms",
        "content_preview",
        "content_length",
        "preview_format",
        "preview_language",
        "content_truncated"
      ]
    },
    "todo_status": {
      "fields": ["source", "total_count", "open_count", "completed_count", "items", "summary_text"]
    },
    "permission_bubble": {
      "fields": ["agent_name", "tool_name", "status", "reason", "requires_confirmation"]
    },
    "runtime_status": {
      "fields": ["phase", "label", "duration_ms", "model", "turn"]
    },
    "system_notice": {
      "fields": ["title", "content", "level"]
    }
  },
  "workbench": {
    "snapshot_fields": ["session_id", "missions", "tasks", "issues", "failures", "events"],
    "event_fields": ["id", "type", "actor", "subject_id", "payload", "timestamp"]
  }
}
