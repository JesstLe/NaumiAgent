# NaumiAgent deployment environment.
# Copy this file to .env and fill the values before running docker compose.

# Required: model provider credentials.
NAUMI_MODELS__API_KEY=replace-with-your-model-api-key
NAUMI_MODELS__API_BASE=https://api.kimi.com/coding/v1

# Optional: comma-free JSON list. Leave [] only for trusted local networks.
# Example: ["naumi-local-key-please-change"]
NAUMI_API__API_KEYS=[]

# Optional runtime limits.
NAUMI_SAFETY__MAX_BUDGET_USD=5.0
NAUMI_API_PORT=8080

# Linux bind-mount ownership. On macOS/Windows Docker Desktop, defaults are fine.
# On Linux, set these with: export HOST_UID=$(id -u) HOST_GID=$(id -g)
HOST_UID=1000
HOST_GID=1000
