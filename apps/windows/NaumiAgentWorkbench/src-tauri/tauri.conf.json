{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NaumiAgentWorkbench",
  "version": "0.1.0",
  "identifier": "com.naumi.workbench",
  "build": {
    "frontendDist": "../../../../frontend/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../../frontend/web && pnpm dev",
    "beforeBuildCommand": "cd ../../../frontend/web && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "NaumiAgent Workbench",
        "width": 1440,
        "height": 1024,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
