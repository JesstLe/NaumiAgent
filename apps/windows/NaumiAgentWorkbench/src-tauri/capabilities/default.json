{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the NaumiAgent Workbench desktop shell",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default"
  ],
  "commands": {
    "allow": [
      "plugin:secure-storage|get_token",
      "plugin:secure-storage|set_token",
      "plugin:secure-storage|remove_token"
    ]
  }
}
