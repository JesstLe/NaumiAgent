{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the NaumiAgent Workbench desktop shell",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "log:default"
  ],
  "commands": {
    "allow": [
      "get_token",
      "set_token",
      "remove_token",
      "get_setting",
      "set_setting",
      "get_daemon_launch_config",
      "set_daemon_launch_config",
      "write_app_log",
      "start_daemon",
      "stop_daemon",
      "get_daemon_status",
      "get_daemon_logs"
    ]
  }
}
